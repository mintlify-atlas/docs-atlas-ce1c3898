  "keyFeatures": [
    "Embeddable Java library for AS4 message exchange (send and receive)",
    "Built-in support for Peppol eDelivery network (OpenPeppol compliant)",
    "CEF eDelivery / BDXL / BDMSL profile support",
    "BDEW (German energy sector) AS4 profile",
    "ENTSOG, EUDAMED, EuCTP, DBNAlliance, and HRE-Delivery profile support",
    "Dynamic SMP/SML endpoint discovery for Peppol and BDXR",
    "WS-Security (WSS4J) signing and encryption support",
    "Servlet-based server for receiving AS4 messages",
    "Profile-based PMode configuration and validation",
    "Retry handling with configurable backoff and message deduplication"
  ],
